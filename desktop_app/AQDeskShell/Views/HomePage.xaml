<Page x:Class="AQDeskShell.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="#EEF3F9">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,14,0"
                    Padding="18"
                    CornerRadius="12"
                    Background="White"
                    BorderBrush="#D9E5F4"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="项目简介" FontSize="22" FontWeight="Bold" Foreground="#17436F" />
                    <TextBlock Margin="0,10,0,16"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="#345D89"
                               Text="本平台用于中国城市空气质量可视化、聚落扩散分析与月历热力解读。桌面应用会自动准备运行环境并托管地图页面，无需用户手工安装依赖。" />
                    <StackPanel Orientation="Horizontal">
                        <Button Width="140" Height="36" Content="初始化环境" Click="InitEnv_OnClick" />
                        <Button Width="180" Height="36" Margin="10,0,0,0" Content="进入地图工作台" Click="OpenWorkbench_OnClick" />
                    </StackPanel>
                    <TextBlock Margin="0,12,0,0" Text="{Binding InitMessage}" Foreground="#4A6A8A" />
                    <ProgressBar Margin="0,8,0,0" Height="8" Minimum="0" Maximum="100" Value="{Binding InitProgress}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Padding="10"
                    CornerRadius="12"
                    Background="White"
                    BorderBrush="#D9E5F4"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="项目 Report" Margin="6,4,0,8" FontWeight="Bold" Foreground="#17436F" />
                    <WebBrowser x:Name="ReportBrowser" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
