<Page x:Class="AQDeskShell.Views.WorkbenchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      mc:Ignorable="d"
      Background="#EEF3F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#D9E5F4" BorderThickness="1" CornerRadius="10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Content="Back Home" Width="110" Grid.Column="0" Click="BackHome_OnClick" />
                <Button Content="Run Main (Hidden)" Width="150" Grid.Column="1" Margin="8,0,0,0" Click="StartAll_OnClick" />
                <Button x:Name="InstallWebViewButton"
                        Content="Install WebView2 Runtime"
                        Width="190"
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        Visibility="Collapsed"
                        Click="InstallWebView2_OnClick" />
                <Button x:Name="FullscreenButton"
                        Content="全屏地图"
                        Width="110"
                        Grid.Column="3"
                        Margin="8,0,0,0"
                        Click="ToggleFullscreen_OnClick" />
                <StackPanel Grid.Column="4" Margin="12,0,0,0">
                    <TextBlock VerticalAlignment="Center" Foreground="#4A6A8A" Text="{Binding WorkbenchStatus}" />
                    <ProgressBar Height="7" Margin="0,5,0,0" Minimum="0" Maximum="100" Value="{Binding RunProgress}" />
                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="#6D87A5" Text="{Binding RunMessage}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,0" Background="White" BorderBrush="#D9E5F4" BorderThickness="1" CornerRadius="10">
            <Grid>
                <wv2:WebView2 x:Name="MapWebView" />
                <Border x:Name="BusyOverlay" Background="#AAFFFFFF" Visibility="Collapsed">
                    <StackPanel Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Preparing map runtime..." FontSize="18" FontWeight="Bold" Foreground="#1A4C7D" HorizontalAlignment="Center" />
                        <ProgressBar Margin="0,10,0,0" Height="10" Minimum="0" Maximum="100" Value="{Binding RunProgress}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding RunMessage}" Foreground="#4F6E90" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
