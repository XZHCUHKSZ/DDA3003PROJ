<Page x:Class="AQDeskShell.Views.WorkbenchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      mc:Ignorable="d"
      Background="#EEF3F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#D9E5F4" BorderThickness="1" CornerRadius="10" Padding="10">
            <DockPanel>
                <Button Content="返回首页" Width="100" DockPanel.Dock="Left" Click="BackHome_OnClick" />
                <Button Content="启动地图" Width="100" Margin="8,0,0,0" DockPanel.Dock="Left" Click="StartAll_OnClick" />
                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#4A6A8A" Text="{Binding WorkbenchStatus}" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,0" Background="White" BorderBrush="#D9E5F4" BorderThickness="1" CornerRadius="10">
            <wv2:WebView2 x:Name="MapWebView" />
        </Border>
    </Grid>
</Page>
